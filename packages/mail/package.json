{
	"name": "@workspace/mail",
	"version": "1.0.0",
	"description": "Mail service with OAuth 2.0 and email templates for Down Under Chauffeur",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./templates": {
			"types": "./dist/templates/index.d.ts",
			"import": "./dist/templates/index.mjs",
			"require": "./dist/templates/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"google-auth-library": "^10.2.1",
		"nodemailer": "^7.0.5"
	},
	"devDependencies": {
		"@types/nodemailer": "^7.0.0",
		"tsup": "^8.0.0",
		"typescript": "catalog:"
	},
	"files": [
		"dist"
	]
}