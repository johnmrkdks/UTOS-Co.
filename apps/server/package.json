{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"exports": {
		"./trpc/routers/_app": "./src/trpc/routers/_app.ts",
		"./types": "./src/types/index.ts"
	},
	"scripts": {
		"build": "tsc --build && wrangler types && wrangler deploy --dry-run",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"check-types": "tsc --noEmit",
		"compile": "pnpm build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "wrangler types && wrangler dev --port=3000 --remote",
		"start": "wrangler dev",
		"deploy": "wrangler types && wrangler deploy",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"db:push-d1": "drizzle-kit push --config=drizzle.d1-config.ts",
		"db:push-supabase": "drizzle-kit push --config=drizzle.supabase-config.ts",
		"db:studio-d1": "drizzle-kit studio --config=drizzle.d1-config.ts",
		"db:studio-supabase": "drizzle-kit studio --config=drizzle.supabase-config.ts",
		"db:generate-d1": "drizzle-kit generate --config=drizzle.d1-config.ts",
		"db:generate-supabase": "drizzle-kit generate --config=drizzle.supabase-config.ts",
		"db:migrate-d1": "drizzle-kit migrate --config=drizzle.d1-config.ts",
		"db:migrate-supabase": "drizzle-kit migrate --config=drizzle.supabase-config.ts"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.4.0",
		"@libsql/client": "^0.15.9",
		"@paralleldrive/cuid2": "^2.2.2",
		"@trpc/server": "^11.4.2",
		"better-auth": "catalog:",
		"dotenv": "^16.4.7",
		"drizzle-orm": "^0.44.3",
		"drizzle-zod": "^0.7.1",
		"hono": "^4.8.2",
		"lodash": "^4.17.21",
		"nuqs": "catalog:",
		"postgres": "^3.4.7",
		"qs": "^6.14.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/lodash": "^4.17.20",
		"@types/qs": "^6.14.0",
		"drizzle-kit": "^0.31.4",
		"tsc-alias": "catalog:",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	}
}
