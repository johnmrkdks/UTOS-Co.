# Utos & Co. — copy to .env and fill in (never commit .env)
CLOUDFLARE_ACCOUNT_ID=
# From: wrangler d1 create (or Cloudflare dashboard)
CLOUDFLARE_DATABASE_ID=
# API token with D1 read (local tooling only)
CLOUDFLARE_D1_TOKEN=
CORS_ORIGIN=http://localhost:3001
BETTER_AUTH_SECRET=REPLACE_ME_BETTER_AUTH_SECRET
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=REPLACE_ME_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME_GOOGLE_CLIENT_SECRET

# Square Payments (optional)
# SQUARE_ACCESS_TOKEN=sq0atp-xxx
# SQUARE_LOCATION_ID=LXXX
# SQUARE_APPLICATION_ID=sq0idp-xxx
# SQUARE_ENVIRONMENT=sandbox
